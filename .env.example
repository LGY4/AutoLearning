# ╔══════════════════════════════════════════════════════════════╗
# ║  AutoLearning — 环境变量配置                                  ║
# ║  复制此文件为 .env 并填入实际值                                ║
# ╚══════════════════════════════════════════════════════════════╝

# ── 应用 ──
APP_NAME=AutoLearning
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-to-a-random-string

# ── 数据库 ──
DATABASE_URL=postgresql+psycopg://autolearning:autolearning@localhost:5432/autolearning
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=autolearning
POSTGRES_USER=autolearning
POSTGRES_PASSWORD=autolearning

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── 存储后端 ──
REPOSITORY_BACKEND=postgres
RAG_BACKEND=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=autolearning_knowledge

# ── LLM: OpenAI-compatible API (DeepSeek / OpenAI / Ollama / vLLM) ──
MODEL_PROVIDER=openai_compatible
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=300

# ── Embedding ──
EMBEDDING_PROVIDER=local
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_ALLOW_FALLBACK=true

# ── Spark (可选) ──
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=wss://spark-api.xf-yun.com/x2
SPARK_MODEL=spark-x

# ── MinIO 对象存储 (可选) ──
MINIO_ROOT_USER=autolearning
MINIO_ROOT_PASSWORD=autolearning123

# ── CORS ──
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
