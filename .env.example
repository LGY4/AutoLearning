APP_NAME=AutoLearning
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://autolearning:autolearning@localhost:5432/autolearning
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=autolearning
POSTGRES_USER=autolearning
POSTGRES_PASSWORD=autolearning
REDIS_URL=redis://localhost:6379/0
VECTOR_STORE=chroma
OBJECT_STORAGE=minio
REPOSITORY_BACKEND=postgres
RAG_BACKEND=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=autolearning_knowledge

# ── LLM: OpenAI-compatible API (DeepSeek / OpenAI / Ollama / vLLM) ──
MODEL_PROVIDER=openai_compatible
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-key-here
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=60

# ── Embedding: OpenAI-compatible API ──
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_API_URL=https://api.deepseek.com/v1/embeddings
EMBEDDING_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_ALLOW_FALLBACK=false

# ── Spark (legacy, optional) ──
SPARK_APP_ID=
SPARK_API_KEY=
SPARK_API_SECRET=
SPARK_API_URL=wss://spark-api.xf-yun.com/v3.5/chat
SPARK_MODEL=generalv3.5
SPARK_JSON_RETRIES=2
