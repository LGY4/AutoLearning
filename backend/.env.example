# ── Required ──
SECRET_KEY=change-me
LLM_API_KEY=your-api-key-here

# ── Storage ──
REPOSITORY_BACKEND=postgres
DATABASE_URL=postgresql+psycopg://autolearning:autolearning@localhost:5432/autolearning
REDIS_URL=redis://localhost:6379/0

# ── LLM (OpenAI-compatible: DeepSeek, OpenAI, Ollama, vLLM) ──
MODEL_PROVIDER=openai_compatible
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-pro
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.4
LLM_TIMEOUT_SECONDS=120

# ── Embedding ──
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_ALLOW_FALLBACK=false
EMBEDDING_DIMENSION=512

# ── Vector store ──
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=autolearning_knowledge

# ── LangGraph ──
LANGGRAPH_MAX_WORKERS=1
LANGGRAPH_TIMEOUT_SECONDS=300

# ── CORS (comma-separated origins) ──
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── HuggingFace image generation (optional) ──
HF_TOKEN=
HF_ENDPOINT=https://api-inference.huggingface.co

# ── Spark (optional legacy) ──
# MODEL_PROVIDER=spark
# SPARK_APP_ID=
# SPARK_API_KEY=
# SPARK_API_SECRET=
# SPARK_API_URL=wss://spark-api.xf-yun.com/x2
# SPARK_MODEL=spark-x

# ── Xfyun digital human video ──
XFYUN_DH_APP_ID=
XFYUN_DH_API_KEY=
XFYUN_DH_API_SECRET=
XFYUN_DH_API_URL=vms.cn-huadong-1.xf-yun.com
XFYUN_DH_PERSONA_ID=
XFYUN_DH_VOICE_ID=
